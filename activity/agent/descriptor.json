{
  "name": "agent-activity",
  "type": "qodeflow:activity",
  "version": "0.0.1",
  "title": "LLM Agent",
  "description": "LLM Agent Activity",
  "homepage": "https://github.com/postqode/qodeflow-component/agent",
  "settings": [
    {
      "name": "provider",
      "type": "string",
      "required": true,
      "allowed": ["openrouter", "postqode"],
      "description": "Model provider (openrouter, postqode)"
    },
    {
      "name": "model",
      "type": "string",
      "required": true,
      "description": "The model name (e.g. anthropic/claude-3-5-sonnet, gemini-2.0-flash)"
    },
    {
      "name": "apiKey",
      "type": "string",
      "description": "Provider API key"
    },
    {
      "name": "systemPrompt",
      "type": "string",
      "description": "Optional system-level instruction for the agent"
    },
    {
      "name": "responseStructure",
      "type": "object",
      "description": "Specifies the JSON schema structure the agent should respond with"
    }
  ],
  "input": [
    {
      "name": "message",
      "type": "string",
      "required": true,
      "description": "User message to send to the agent"
    }
  ],
  "output": [
    {
      "name": "response",
      "type": "string",
      "description": "Text response generated by the agent"
    }
  ]
}
