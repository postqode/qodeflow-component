{
    "name": "qodeflow-awss3",
    "type": "qodeflow:activity",
    "version": "0.1.0",
    "title": "AWS S3",
    "description": "Performs object storage operations in AWS S3",
    "homepage": "https://github.com/postqode/qodeflow-component/tree/main/activity/aws-s3",
    "settings": [
        {
            "name": "region",
            "type": "string",
            "required": true,
            "description": "The AWS region"
        },
        {
            "name": "accessKeyID",
            "type": "string",
            "required": false,
            "description": "The AWS Access Key ID"
        },
        {
            "name": "secretAccessKey",
            "type": "string",
            "required": false,
            "description": "The AWS Secret Access Key"
        },
        {
            "name": "sessionToken",
            "type": "string",
            "required": false,
            "description": "The AWS Session Token"
        }
    ],
    "input": [
        {
            "name": "method",
            "type": "string",
            "required": true,
            "description": "The S3 operation to perform (Upload, Download, List, Delete)"
        },
        {
            "name": "bucket",
            "type": "string",
            "required": true,
            "description": "The S3 bucket name"
        },
        {
            "name": "key",
            "type": "string",
            "required": true,
            "description": "The S3 object key or prefix for List operation"
        },
        {
            "name": "data",
            "type": "any",
            "description": "The data to upload (for Upload operation)"
        },
        {
            "name": "localPath",
            "type": "string",
            "description": "The local file path (for Download operation)"
        }
    ],
    "output": [
        {
            "name": "success",
            "type": "boolean",
            "description": "Whether the operation was successful"
        },
        {
            "name": "error",
            "type": "string",
            "description": "Error message if the operation failed"
        },
        {
            "name": "result",
            "type": "any",
            "description": "The result of the operation (e.g., list of keys for List)"
        }
    ]
}