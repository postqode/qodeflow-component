{
    "name": "qodeflow-webhook",
    "type": "qodeflow:trigger",
    "version": "0.1.0",
    "title": "Receive Webhook",
    "description": "Trigger flows via HTTP Webhooks",
    "homepage": "https://github.com/postqode/qodeflow-contrib/tree/main/trigger/webhook",
    "settings": [
        {
            "name": "port",
            "type": "int",
            "required": true,
            "description": "The port to listen on"
        }
    ],
    "output": [
        {
            "name": "pathParams",
            "type": "params",
            "description": "The path parameters"
        },
        {
            "name": "queryParams",
            "type": "params",
            "description": "The query parameters"
        },
        {
            "name": "headers",
            "type": "params",
            "description": "The HTTP header parameters"
        },
        {
            "name": "method",
            "type": "string",
            "description": "The HTTP method used"
        },
        {
            "name": "content",
            "type": "any",
            "description": "The content of the request"
        }
    ],
    "reply": [
        {
            "name": "code",
            "type": "int",
            "description": "The http code to reply with"
        },
        {
            "name": "data",
            "type": "any",
            "description": "The data to reply with"
        }
    ],
    "handler": {
        "settings": [
            {
                "name": "method",
                "type": "string",
                "required": true,
                "allowed": [
                    "GET",
                    "POST",
                    "PUT",
                    "PATCH",
                    "DELETE"
                ],
                "description": "The HTTP method"
            },
            {
                "name": "path",
                "type": "string",
                "required": true,
                "description": "The resource path"
            }
        ]
    }
}